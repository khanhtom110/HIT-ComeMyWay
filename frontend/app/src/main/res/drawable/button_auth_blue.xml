<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_pressed="true">
        <layer-list>
            <item android:top="5dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/colorPrimary" /> <corners android:radius="100dp" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/colorsecondary" /> <corners android:radius="100dp" />
                </shape>
            </item>

            <item android:bottom="5dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/colorPrimary" /> <corners android:radius="100dp" />
                </shape>
            </item>
        </layer-list>
    </item>

</selector>