<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/colorBackground"
    tools:context=".ui.home.informationroom.InformationRoomFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/back"
            android:layout_width="@dimen/_16sdp"
            android:layout_height="@dimen/_16sdp"
            android:src="@drawable/back"
            android:layout_marginTop="@dimen/_40sdp"
            android:layout_marginStart="@dimen/_21sdp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            style="@style/Nut3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thông tin phòng khám"
            android:textColor="@color/colorTextSub"
            android:layout_marginTop="@dimen/_40sdp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:background="@drawable/modes"
            android:layout_marginHorizontal="@dimen/_16sdp"
            android:layout_marginVertical="@dimen/_8sdp"
            app:layout_constraintTop_toBottomOf="@id/back"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/image"
                android:layout_width="@dimen/_60sdp"
                android:layout_height="@dimen/_60sdp"
                android:src="@drawable/image_test"
                android:layout_marginTop="@dimen/_16sdp"
                android:layout_marginStart="@dimen/_20sdp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                style="@style/Nut2"
                android:id="@+id/nameRoom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phòng khám thú y Funvet"
                android:layout_marginTop="@dimen/_19sdp"
                android:layout_marginStart="@dimen/_10sdp"
                android:textColor="@color/colorTextSub"
                app:layout_constraintStart_toEndOf="@id/image"
                app:layout_constraintTop_toTopOf="parent"/>

            <ImageView
                android:id="@+id/image_status"
                android:layout_width="@dimen/_8sdp"
                android:layout_height="@dimen/_8sdp"
                android:src="@drawable/status"
                android:layout_marginStart="@dimen/_10sdp"
                android:layout_marginTop="@dimen/_5sdp"
                app:layout_constraintTop_toBottomOf="@id/nameRoom"
                app:layout_constraintStart_toEndOf="@id/image"/>

            <TextView
                style="@style/Chu2"
                android:id="@+id/action"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đang hoạt động"
                android:textColor="@color/colorTextContent"
                android:layout_marginStart="@dimen/_4sdp"
                app:layout_constraintTop_toBottomOf="@id/nameRoom"
                app:layout_constraintStart_toEndOf="@id/image_status"/>

            <ImageView
                android:id="@+id/image_rating"
                android:layout_width="@dimen/_8sdp"
                android:layout_height="@dimen/_8sdp"
                android:src="@drawable/rating"
                android:layout_marginStart="@dimen/_10sdp"
                android:layout_marginTop="@dimen/_5sdp"
                app:layout_constraintTop_toBottomOf="@id/action"
                app:layout_constraintStart_toEndOf="@id/image"/>

            <TextView
                style="@style/Chu2"
                android:id="@+id/rating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đánh giá: 4.8/5"
                android:textColor="@color/colorTextContent"
                android:layout_marginStart="@dimen/_4sdp"
                app:layout_constraintTop_toBottomOf="@id/action"
                app:layout_constraintStart_toEndOf="@id/image_rating"/>

            <TextView
                style="@style/Chu2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Giới thiệu"
                android:textColor="@color/colorTextSub"
                android:layout_marginTop="@dimen/_24sdp"
                android:layout_marginStart="@dimen/_20sdp"
                app:layout_constraintTop_toBottomOf="@id/image"
                app:layout_constraintStart_toStartOf="parent"/>




        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>