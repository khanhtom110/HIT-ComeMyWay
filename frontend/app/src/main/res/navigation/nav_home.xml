<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_home"
    app:startDestination="@id/bookFragment">

    <fragment
        android:id="@+id/bookFragment"
        android:name="com.example.petbeats.ui.home.book.BookFragment"
        android:label="bookFragment"/>

    <fragment
        android:id="@+id/newsFragment"
        android:name="com.example.petbeats.ui.home.news.NewsFragment"
        android:label="newsFragmnet"/>

    <fragment
        android:id="@+id/locketFragment"
        android:name="com.example.petbeats.ui.home.locket.LocketFragment"
        android:label="locketFragment"/>

    <fragment
        android:id="@+id/petFragment"
        android:name="com.example.petbeats.ui.home.pet.PetFragment"
        android:label="petFragment"/>

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.example.petbeats.ui.home.search.SearchFragment"
        android:label="searchFragment">
        <action
            android:id="@+id/search_book"
            app:destination="@+id/bookFragment"
            app:popUpTo="@id/bookFragment"
            app:popUpToInclusive="true"/>
    </fragment>
</navigation>